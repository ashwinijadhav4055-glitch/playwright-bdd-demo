{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@api/*": ["src/api/*"],
      "@support/*": ["src/support/*"],
      "@fixtures/*": ["fixtures/*"]
    }
  },
  "include": [
    "src/**/*",
    "step-definitions/**/*",
    "features/**/*",
    "*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
